{
  "name": "sidangready-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "lint": "npm --workspace apps/web run lint",
    "build": "npm --workspace apps/web run build",
    "api:compile": "python -m compileall apps/api/app",
    "api:test": "python -m unittest discover -s apps/api/tests -t apps/api",
    "api:migration:sql": "alembic -c apps/api/alembic.ini upgrade head --sql",
    "check": "npm run lint && npm run build && npm run api:compile && npm run api:test && npm run api:migration:sql"
  }
}
